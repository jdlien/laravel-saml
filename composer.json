{
  "name": "jdlien/laravel-saml",
  "description": "SAML toolkit for Laravel based on OneLogin's SAML PHP Toolkit.",
  "license": "MIT",
  "type": "library",
  "keywords": [
    "laravel",
    "saml",
    "saml2",
    "sso",
    "authentication",
    "onelogin"
  ],
  "homepage": "https://github.com/jdlien/laravel-saml",
  "support": {
    "issues": "https://github.com/jdlien/laravel-saml/issues",
    "source": "https://github.com/jdlien/laravel-saml"
  },
  "authors": [
    {
      "name": "JD Lien",
      "email": "jd@jdlien.com"
    }
  ],
  "require": {
    "php": "^8.3",
    "ext-dom": "*",
    "ext-libxml": "*",
    "ext-openssl": "*",
    "ext-zlib": "*",
    "laravel/framework": "^12.0|^13.0",
    "onelogin/php-saml": "^4.3.1"
  },
  "conflict": {
    "overtrue/laravel-saml": "*"
  },
  "require-dev": {
    "pestphp/pest": "^4.4.1",
    "pestphp/pest-plugin-laravel": "^4.1",
    "pestphp/pest-plugin-mutate": "^4.0",
    "orchestra/testbench": "^10.0|^11.0",
    "mockery/mockery": "^1.6",
    "laravel/pint": "^1.18",
    "larastan/larastan": "^3.0"
  },
  "autoload": {
    "psr-4": {
      "Jdlien\\LaravelSaml\\": "src"
    },
    "files": [
      "src/compat.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Jdlien\\LaravelSaml\\SamlServiceProvider"
      ]
    }
  },
  "scripts": {
    "test": "vendor/bin/pest",
    "test:coverage": "vendor/bin/pest --coverage --min=95",
    "test:mutate": "vendor/bin/pest --mutate",
    "analyse": "vendor/bin/phpstan analyse",
    "check-style": "vendor/bin/pint --test",
    "fix-style": "vendor/bin/pint"
  },
  "scripts-descriptions": {
    "test": "Run the Pest test suite.",
    "test:coverage": "Run tests with coverage, enforcing the 95% minimum.",
    "test:mutate": "Run mutation tests (informational, not blocking).",
    "analyse": "Run Larastan static analysis.",
    "check-style": "Check code style without fixing.",
    "fix-style": "Fix code style violations."
  },
  "config": {
    "allow-plugins": {
      "pestphp/pest-plugin": true
    },
    "sort-packages": true
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
